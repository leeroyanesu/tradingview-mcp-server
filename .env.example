# TradingView Session Credentials
# Get these from your browser cookies when logged into TradingView
# 1. Log into TradingView in your browser
# 2. Open Developer Tools (F12)
# 3. Go to Application/Storage > Cookies > https://www.tradingview.com
# 4. Copy the values of 'sessionid' and 'sessionid_sign' cookies

TRADINGVIEW_SESSION_ID=your_session_id_here
TRADINGVIEW_SESSION_ID_SIGN=your_session_id_sign_here

MT5_LOGIN=account_no
MT5_PASSWORD=account_pwd
MT5_SERVER=account_server

MT5_PATH=C:\Program Files\MetaTrader 5 Terminal\terminal64.exe